# Variables de entorno — Messenger Clone
# Copia este archivo como .env.local y llena los valores

# Supabase
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# JWT (clave secreta para firmar tokens — generar con getRandomValues, mínimo 64 chars hex)
JWT_SECRET=cambiar_por_clave_secreta_larga_y_aleatoria

# Clave maestra para cifrado at-rest (Capa 2 del triple cifrado — generar con getRandomValues, 64 chars hex = 256 bits)
ENCRYPTION_MASTER_KEY=cambiar_por_clave_maestra_de_256_bits_hex

# Web Push VAPID keys (se generarán en Fase 18)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Entorno
NODE_ENV=development
